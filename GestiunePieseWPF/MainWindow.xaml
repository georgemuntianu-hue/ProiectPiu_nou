<Window x:Class="GestiunePieseWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Piese Auto - Tema" Height="500" Width="900" Background="#F0F2F5" MinWidth="700" MinHeight="450">
    <Window.Resources>
        <!-- Stiluri Comune (Cerința 5) -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBox" x:Key="InputStyle">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Border.CornerRadius" Value="4"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Meniu (Cerința 1) -->
        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="5">
            <MenuItem Header="_Fișier">
                <MenuItem Header="_Ieșire" Click="MnuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Ajutor">
                <MenuItem Header="_Despre" Click="MnuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- Layout Responsive cu Grid (Cerința 1) -->
        <TabControl Margin="15" BorderThickness="0" Background="Transparent">
            <TabItem Header="Piese Auto" Background="White">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Căutare (Cerința 3) -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="15,0,0,15">
                        <TextBlock Text="Căutare (Nume/Cod):" VerticalAlignment="Center" Style="{StaticResource LabelStyle}" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtCautare" Width="250" Style="{StaticResource InputStyle}" Margin="0" TextChanged="TxtCautare_TextChanged" Padding="5"/>
                    </StackPanel>

                    <!-- Formular Adăugare -->
                    <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled" Padding="0,0,5,0" Grid.ColumnSpan="2" Margin="10,10,476,-10">
                        <Border Background="White" CornerRadius="10" Padding="15" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="ADĂUGARE PIESĂ" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>

                                <TextBlock Text="Nume Produs:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="txtNume" Style="{StaticResource InputStyle}"/>

                                <TextBlock Text="Cod Identificare:" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="txtCod" Style="{StaticResource InputStyle}"/>

                                <TextBlock Text="Preț (RON):" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="txtPret" Style="{StaticResource InputStyle}"/>

                                <TextBlock Text="Categorie:" Style="{StaticResource LabelStyle}"/>
                                <ComboBox x:Name="cmbCategorie" Margin="0,2,0,8" Padding="3" IsEditable="True" IsTextSearchEnabled="True"/>

                                <TextBlock Text="Data Adăugare:" Style="{StaticResource LabelStyle}"/>
                                <DatePicker x:Name="dpDataAdaugare" Margin="0,2,0,8" Padding="3"/>

                                <!-- RadioButtons pentru Locație (Cerința 2) -->
                                <TextBlock Text="Locație:" Style="{StaticResource LabelStyle}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                                    <RadioButton x:Name="rbDepozit" Content="Depozit" IsChecked="True" Margin="0,0,15,0"/>
                                    <RadioButton x:Name="rbMagazin" Content="Magazin" Margin="0,0,15,0"/>
                                    <RadioButton x:Name="rbFurnizor" Content="Furnizor"/>
                                </StackPanel>

                                <!-- CheckBox pentru Disponibilitate (Cerința 2) -->
                                <CheckBox x:Name="chkOnline" Content="Disponibil pentru comandă online" Margin="0,0,0,15" FontWeight="SemiBold"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                    <Button Content="SALVEAZĂ PIESA" Click="BtnAdauga_Click" Style="{StaticResource PrimaryButtonStyle}" Width="145" Margin="0,0,10,0"/>
                                    <Button x:Name="btnModifica" Content="MODIFICĂ PIESA" Click="BtnModifica_Click" Style="{StaticResource PrimaryButtonStyle}" Width="145" Background="#F39C12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- Lista de Piese -->
                    <GroupBox Header="PIESE ÎNREGISTRATE" Grid.Row="1" Grid.Column="1" Margin="15,0,0,0" Padding="10" Background="White" BorderBrush="#E0E0E0">
                        <ListBox x:Name="lstPiese" SelectionChanged="LstPiese_SelectionChanged" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Nume}" FontSize="17" FontWeight="Bold" Foreground="#2C3E50"/>
                                                <Border Background="LightGreen" CornerRadius="4" Padding="5,2" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="{Binding EsteDisponibilOnline, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Online" FontSize="10" FontWeight="Bold" Foreground="DarkGreen"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Foreground="Gray" Margin="0,5,0,0">
                                        <Run Text="Cod: "/><Run Text="{Binding CodPiesa}"/>
                                        <Run Text=" | Categorie: "/><Run Text="{Binding Categorie}"/>
                                        <Run Text=" | Locație: "/><Run Text="{Binding Locatie}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DataAdaugareFormatata}" Foreground="Gray" Margin="0,2,0,0" FontSize="12"/>
                                            <TextBlock Text="{Binding PretAfisare}" FontSize="16" FontWeight="Bold" Foreground="Green" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Tab Furnizori (Cerința 1 - CRUD a doua entitate, Cerința 2 - Binding 2 controale) -->
            <TabItem Header="Furnizori" Background="White">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Formular Adăugare / Modificare Furnizor -->
                    <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled" Padding="0,0,5,0">
                        <Border Background="White" CornerRadius="10" Padding="15" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="GESTIUNE FURNIZOR" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>

                                <TextBlock Text="Nume Furnizor:" Style="{StaticResource LabelStyle}"/>
                                <!-- BINDING 1: TextBox pentru Nume -->
                                <TextBox x:Name="txtFurnizorNume" Style="{StaticResource InputStyle}"
                                     Text="{Binding ElementName=lstFurnizori, Path=SelectedItem.Nume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="CIF:" Style="{StaticResource LabelStyle}"/>
                                <!-- BINDING 2: TextBox pentru CIF -->
                                <TextBox x:Name="txtFurnizorCIF" Style="{StaticResource InputStyle}"
                                     Text="{Binding ElementName=lstFurnizori, Path=SelectedItem.CIF, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="Telefon:" Style="{StaticResource LabelStyle}"/>
                                <!-- BINDING 3: TextBox pentru Telefon -->
                                <TextBox x:Name="txtFurnizorTelefon" Style="{StaticResource InputStyle}"
                                     Text="{Binding ElementName=lstFurnizori, Path=SelectedItem.Telefon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="Notă: Modificările din câmpuri se salvează automat datorită Data Binding-ului (Two-Way)." 
                                       Foreground="Gray" FontSize="11" Margin="0,0,0,15" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                    <Button Content="ADĂUGĂ FURNIZOR" Click="BtnAdaugaFurnizor_Click" Style="{StaticResource PrimaryButtonStyle}" Width="145" Margin="0,0,10,0"/>
                                    <Button Content="ȘTERGE FURNIZOR" Click="BtnStergeFurnizor_Click" Style="{StaticResource PrimaryButtonStyle}" Width="145" Background="#E74C3C"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- Lista de Furnizori -->
                    <GroupBox Header="FURNIZORI ÎNREGISTRAȚI" Grid.Row="1" Grid.Column="1" Margin="15,0,0,0" Padding="10" Background="White" BorderBrush="#E0E0E0">
                        <ListBox x:Name="lstFurnizori" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nume}" FontSize="17" FontWeight="Bold" Foreground="#2C3E50"/>
                                            <TextBlock Foreground="Gray" Margin="0,5,0,0">
                                                <Run Text="CIF: "/><Run Text="{Binding CIF}"/>
                                                <Run Text=" | Telefon: "/><Run Text="{Binding Telefon}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>