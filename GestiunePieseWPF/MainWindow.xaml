<Window x:Class="GestiunePieseWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Piese Auto - Tema" Height="600" Width="900" Background="#F0F2F5" MinWidth="700" MinHeight="450">
    <Window.Resources>
        <!-- Stiluri Comune (Cerința 5) -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBox" x:Key="InputStyle">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Border.CornerRadius" Value="4"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Meniu (Cerința 1) -->
        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="5">
            <MenuItem Header="_Fișier">
                <MenuItem Header="_Ieșire" Click="MnuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Ajutor">
                <MenuItem Header="_Despre" Click="MnuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- Layout Responsive cu Grid (Cerința 1) -->
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Căutare (Cerința 3) -->
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="15,0,0,15">
                <TextBlock Text="Căutare (Nume/Cod):" VerticalAlignment="Center" Style="{StaticResource LabelStyle}" Margin="0,0,10,0"/>
                <TextBox x:Name="txtCautare" Width="250" Style="{StaticResource InputStyle}" Margin="0" TextChanged="TxtCautare_TextChanged" Padding="5"/>
            </StackPanel>

            <!-- Formular Adăugare -->
            <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="10" Padding="20" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="ADĂUGARE PIESĂ" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,20"/>

                    <TextBlock Text="Nume Produs:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtNume" Style="{StaticResource InputStyle}"/>

                    <TextBlock Text="Cod Identificare:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtCod" Style="{StaticResource InputStyle}"/>

                    <TextBlock Text="Preț (RON):" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtPret" Style="{StaticResource InputStyle}"/>

                    <TextBlock Text="Categorie:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="cmbCategorie" Margin="0,5,0,15" Padding="5" IsEditable="True" IsTextSearchEnabled="True"/>

                    <TextBlock Text="Data Adăugare:" Style="{StaticResource LabelStyle}"/>
                    <DatePicker x:Name="dpDataAdaugare" Margin="0,5,0,15" Padding="5"/>

                    <!-- RadioButtons pentru Locație (Cerința 2) -->
                    <TextBlock Text="Locație:" Style="{StaticResource LabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                        <RadioButton x:Name="rbDepozit" Content="Depozit" IsChecked="True" Margin="0,0,15,0"/>
                        <RadioButton x:Name="rbMagazin" Content="Magazin" Margin="0,0,15,0"/>
                        <RadioButton x:Name="rbFurnizor" Content="Furnizor"/>
                    </StackPanel>

                    <!-- CheckBox pentru Disponibilitate (Cerința 2) -->
                    <CheckBox x:Name="chkOnline" Content="Disponibil pentru comandă online" Margin="0,0,0,25" FontWeight="SemiBold"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <Button Content="SALVEAZĂ PIESA" Click="BtnAdauga_Click" Style="{StaticResource PrimaryButtonStyle}" Width="145" Margin="0,0,10,0"/>
                        <Button x:Name="btnModifica" Content="MODIFICĂ PIESA" Click="BtnModifica_Click" Style="{StaticResource PrimaryButtonStyle}" Width="145" Background="#F39C12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Lista de Piese -->
            <GroupBox Header="PIESE ÎNREGISTRATE" Grid.Row="1" Grid.Column="1" Margin="15,0,0,0" Padding="10" Background="White" BorderBrush="#E0E0E0">
                <ListBox x:Name="lstPiese" SelectionChanged="LstPiese_SelectionChanged" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Nume}" FontSize="17" FontWeight="Bold" Foreground="#2C3E50"/>
                                        <Border Background="LightGreen" CornerRadius="4" Padding="5,2" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="{Binding EsteDisponibilOnline, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Online" FontSize="10" FontWeight="Bold" Foreground="DarkGreen"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Foreground="Gray" Margin="0,5,0,0">
                                        <Run Text="Cod: "/><Run Text="{Binding CodPiesa}"/>
                                        <Run Text=" | Categorie: "/><Run Text="{Binding Categorie}"/>
                                        <Run Text=" | Locație: "/><Run Text="{Binding Locatie}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DataAdaugareFormatata}" Foreground="Gray" Margin="0,2,0,0" FontSize="12"/>
                                    <TextBlock Text="{Binding PretAfisare}" FontSize="16" FontWeight="Bold" Foreground="Green" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>